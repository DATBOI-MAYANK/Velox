# ============================================================
# Root .env.example — Docker Compose variable interpolation
# Copy this file as .env and replace all placeholder values.
# These are injected into the API containers via docker-compose.yml.
# ============================================================

# REQUIRED — 64-char random hex strings for signing JWTs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX

# OPTIONAL — Token expiry durations
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# REQUIRED — Frontend URL for CORS (must match what the browser uses)
# Local Docker: http://localhost
# Production:   https://velox.yourdomain.com
CLIENT_URL=http://localhost

# OPTIONAL — Mistral AI API key (enables AI ticket routing and auto-replies)
MISTRAL_API_KEY=

# OPTIONAL — HMAC secret for widget API key generation
API_KEY_SECRET=REPLACE_WITH_64_CHAR_HEX
