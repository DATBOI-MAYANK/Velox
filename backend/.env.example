NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/velox?retryWrites=true&w=majority

# Optional — if blank, blacklist/cache is skipped (single-instance dev only)
REDIS_URL=

JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=replace-with-different-openssl-rand-base64-48
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

CLIENT_URL=http://localhost:5173
API_KEY_SECRET=replace-with-openssl-rand-base64-32

# Optional — without this, AI service runs in stub fallback
MISTRAL_API_KEY=
