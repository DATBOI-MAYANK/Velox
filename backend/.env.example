# ============================================================
# Velox Backend — Environment Variables
# Copy this file as .env and fill in all REQUIRED values.
# ============================================================

# REQUIRED — Must be "production" for live deployment
NODE_ENV=production

# REQUIRED — Port the Node.js server listens on (Docker internal)
PORT=5000

# REQUIRED — MongoDB connection string
# Docker Compose: mongodb://mongo:27017/velox
# Atlas:          mongodb+srv://<user>:<pass>@cluster.mongodb.net/velox
MONGODB_URI=mongodb://mongo:27017/velox

# REQUIRED — 64-char random hex strings for signing JWTs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX

# OPTIONAL — Token expiry durations (defaults shown)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# REQUIRED for production — Redis connection string
# Enables: token blacklisting, Socket.IO cross-replica sync, rate limiting
# Docker Compose: redis://redis:6379
REDIS_URL=redis://redis:6379

# REQUIRED — Frontend URL for strict CORS enforcement
# Must match exactly what the browser uses (protocol + host + port if non-standard)
# Docker Compose (Nginx on port 80): http://localhost
# Custom domain: https://velox.yourdomain.com
CLIENT_URL=http://localhost

# OPTIONAL — Mistral AI API key for ticket classification, auto-reply, and summaries
# Get one at: https://console.mistral.ai/
MISTRAL_API_KEY=

# OPTIONAL — HMAC secret for widget API key generation
API_KEY_SECRET=REPLACE_WITH_64_CHAR_HEX
