VITE_APP_NAME=Velox

# Backend ORIGIN only — `/api` is appended automatically by api/client.js.
# Examples:
#   Local dev:  http://localhost:5000
#   Prod:       https://api.velox.example.com
VITE_API_URL=http://localhost:5000

# Backend target for the Vite dev proxy (used by vite.config.js, optional).
VITE_API_TARGET=http://localhost:5000

# Socket.IO origin. Falls back to VITE_API_URL when unset.
VITE_SOCKET_URL=http://localhost:5000

# Mock layer (MSW + mock socket). Defaults: ON in dev, OFF in prod.
# Set to "false" to hit the real backend in dev.
VITE_USE_MOCK=true
