# ============================================================
# Velox Frontend — Environment Variables
# Copy this file as .env and fill in all values.
# These are baked into the bundle at build time by Vite.
# ============================================================

# REQUIRED — Backend API URL (the origin the browser uses to reach Nginx)
# Docker Compose (Nginx on port 80): http://localhost
# Custom domain: https://velox.yourdomain.com
VITE_API_URL=http://localhost

# REQUIRED — Socket.IO URL (same origin — Nginx routes /socket.io/ to backend)
VITE_SOCKET_URL=http://localhost

# REQUIRED — Set to "false" to use the real backend (not MSW mocks)
VITE_USE_MOCK=false

# OPTIONAL — App display name
VITE_APP_NAME=Velox

# OPTIONAL — Widget API key for the embedded chat widget
VITE_WIDGET_API_KEY=
